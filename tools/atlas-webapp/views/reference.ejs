<%- include('partials/head', {title, includeCharts: false}) %>
<%- include('partials/nav', {activeNav}) %>

<style>
  /* ── jump nav ── */
  .ref-jump { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .ref-jump a { font-size: 12px; color: var(--muted); background: var(--bg3); border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; text-decoration: none; transition: color .15s, border-color .15s; }
  .ref-jump a:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

  /* ── grid layout ── */
  .ref-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; align-items: stretch; }
  @media (max-width: 800px) { .ref-grid { grid-template-columns: 1fr; } }
  .ref-section { margin-bottom: 0; display: grid; }
  .ref-grid .window-wrap { margin-bottom: 0; }

  /* ── tables ── */
  .method-badge { display: inline-block; font-family: monospace; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; letter-spacing: .5px; }
  .method-get  { background: rgba(52,211,153,.15); color: #34d399; }
  .method-post { background: rgba(251,146,60,.15);  color: #fb923c; }
  .ref-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .ref-table th { color: var(--muted); font-weight: 600; text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; }
  .ref-table td { padding: 9px 10px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top; }
  .ref-table tr:last-child td { border-bottom: none; }
  .ref-table tr:hover td { background: rgba(255,255,255,0.02); }
  .ref-table code { font-size: 12px; color: var(--muted); }
  .path-cell { font-family: monospace; font-size: 12px; color: #c792ea; }
  .route-path { font-family: monospace; font-size: 12px; color: #82aaff; }

  /* ── misc shared ── */
  .port-pill { display: inline-block; font-family: monospace; font-size: 11px; background: rgba(96,165,250,.12); color: #60a5fa; border-radius: 4px; padding: 2px 8px; }
  .model-pill { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 600; }
  .model-opus   { background: rgba(232,68,90,.15); color: #e8445a; }
  .model-sonnet { background: rgba(96,165,250,.15); color: #60a5fa; }
  .model-haiku  { background: rgba(134,239,172,.15); color: #86efac; }

  /* ── lifecycle ── */
  .lifecycle-grid { display: grid; grid-template-columns: auto 28px auto 28px auto; grid-template-rows: auto 24px auto; align-items: center; justify-items: center; margin: 16px 0; }
  .lifecycle-box { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 16px; text-align: center; min-width: 110px; }
  .lifecycle-box .lbl { font-size: 11px; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .5px; }
  .lifecycle-box.state-queue  { border-color: rgba(251,191,36,.3);  }
  .lifecycle-box.state-active { border-color: rgba(52,211,153,.3);  }
  .lifecycle-box.state-done   { border-color: rgba(96,165,250,.3);  }
  .lifecycle-box.state-failed { border-color: rgba(239,68,68,.3);   }
  .lifecycle-arrow { color: var(--muted); font-size: 18px; }

  /* ── config block ── */
  .config-block { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; font-family: monospace; font-size: 12px; color: var(--muted); line-height: 1.7; overflow-x: auto; margin-top: 12px; white-space: pre; }
  .config-key   { color: #82aaff; }
  .config-val   { color: #c3e88d; }
  .config-comment { color: #4a5568; }

  /* ── slash commands ── */
  .cmd-row { display: flex; gap: 10px; align-items: baseline; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .cmd-row:last-child { border-bottom: none; }
  .cmd-name { font-family: monospace; font-size: 13px; color: #c792ea; min-width: 180px; flex-shrink: 0; }
  .cmd-desc { font-size: 13px; color: var(--muted); }

  /* ── architecture diagram ── */
  .arch-wrap { display: grid; grid-template-columns: 1fr 272px; gap: 20px; align-items: start; }
  @media (max-width: 960px) { .arch-wrap { grid-template-columns: 1fr; } }

  .arch-box { border: 1.5px dashed rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 10px 10px; margin-top: 10px; }
  .arch-box-windows { border-color: rgba(140,160,220,0.25); margin-top: 0; }
  .arch-box-wsl     { border-color: rgba(134,239,172,0.25); }
  .arch-box-docker  { border-color: rgba(96,165,250,0.25); }

  .arch-box-hdr { display: flex; align-items: center; justify-content: space-between; padding: 3px 4px; margin: -3px -4px 8px; border-radius: 6px; cursor: pointer; user-select: none; }
  .arch-box-hdr:hover { background: rgba(255,255,255,0.03); }
  .arch-box-hdr:hover .arch-hint { opacity: 1; }
  .arch-box-tag { font-size: 10px; text-transform: uppercase; letter-spacing: .7px; font-weight: 700; }
  .arch-hint { font-size: 10px; color: var(--muted2); opacity: 0; transition: opacity .15s; }

  .arch-svc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; }
  .arch-host-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 7px; margin-top: 8px; }
  .arch-ext-row  { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 7px; margin-top: 10px; }

  .arch-node { background: var(--bg3); border: 1px solid var(--border); border-radius: 7px; padding: 9px 11px; cursor: pointer; transition: border-color .15s, background .15s; }
  .arch-node:hover { border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.025); }
  .arch-node.arch-active { border-color: var(--red) !important; background: rgba(232,68,90,.07) !important; }
  .arch-node-name { font-size: 12px; font-weight: 600; }
  .arch-node-sub  { font-size: 11px; color: var(--muted); margin-top: 2px; }

  .arch-panel { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 18px; min-height: 260px; display: flex; flex-direction: column; min-width: 0; overflow: hidden; }
  .arch-panel-hint { font-size: 13px; color: var(--muted2); text-align: center; margin: auto; line-height: 1.8; }
  .arch-panel-title { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
  .arch-panel-sub   { font-size: 12px; color: var(--muted); margin-bottom: 14px; }
  .arch-panel-facts { width: 100%; }
  .arch-pf-row { display: flex; gap: 8px; padding: 4px 0; font-size: 12px; border-bottom: 1px solid rgba(255,255,255,0.03); }
  .arch-pf-row:last-child { border-bottom: none; }
  .arch-pf-key { flex: 0 0 44%; min-width: 0; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .arch-pf-val { flex: 1; min-width: 0; font-family: monospace; font-size: 11px; color: var(--text); word-break: break-word; overflow: hidden; }
  .arch-panel-note { font-size: 12px; color: var(--muted); margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border); line-height: 1.6; font-style: italic; }

  /* ── tech cards ── */
  .tech-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 10px; }
  .tech-group-label { font-size: 11px; text-transform: uppercase; letter-spacing: .6px; color: var(--muted); margin: 18px 0 8px; font-weight: 600; }
  .tech-group-label:first-child { margin-top: 0; }
  .tech-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 13px 14px; }
  .tech-card:hover { border-color: rgba(255,255,255,0.13); }
  .tech-card-head { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
  .tech-card-name { font-size: 13px; font-weight: 700; }
  .tech-card-ver  { font-family: monospace; font-size: 10px; color: var(--muted); background: rgba(255,255,255,0.05); border-radius: 4px; padding: 1px 6px; }
  .tech-card-role { font-size: 12px; color: var(--muted); line-height: 1.55; }
  .tech-card-file { font-family: monospace; font-size: 11px; color: #c792ea; margin-top: 8px; display: block; }

  /* ── troubleshooting ── */
  .trouble-list { display: flex; flex-direction: column; gap: 6px; }
  details.trouble { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  details.trouble[open] { border-color: rgba(255,255,255,0.12); }
  details.trouble summary { padding: 11px 16px; cursor: pointer; font-size: 13px; font-weight: 600; list-style: none; display: flex; align-items: center; gap: 10px; user-select: none; }
  details.trouble summary::-webkit-details-marker { display: none; }
  details.trouble summary::before { content: '›'; color: var(--muted); font-size: 16px; line-height: 1; transition: transform .2s; display: inline-block; width: 14px; }
  details.trouble[open] summary::before { transform: rotate(90deg); }
  .trouble-symptom { font-size: 11px; color: var(--muted); font-weight: 400; margin-left: 4px; }
  .trouble-body { padding: 0 16px 16px; border-top: 1px solid var(--border); margin-top: 2px; }
  .trouble-label { font-size: 11px; text-transform: uppercase; letter-spacing: .5px; color: var(--muted); margin: 12px 0 5px; }
  .trouble-cmd { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; font-family: monospace; font-size: 11px; color: #c3e88d; margin-top: 6px; white-space: pre-wrap; line-height: 1.7; }
  .trouble-note { font-size: 12px; color: var(--muted); margin-top: 8px; line-height: 1.6; }

  .service-row td:first-child { font-family: monospace; font-size: 12px; color: #c792ea; }
</style>

<section class="hero" style="min-height:22vh">
  <div class="hero-glow"></div>
  <h1>Technical Reference</h1>
  <p class="hero-sub">Architecture, API, agents, data schemas, configuration, and troubleshooting.</p>
  <div class="ref-jump">
    <a href="#architecture">Architecture</a>
    <a href="#stack">Stack</a>
    <a href="#layout">Directory</a>
    <a href="#api">API</a>
    <a href="#tasks">Tasks</a>
    <a href="#agents">Agents</a>
    <a href="#data">Data Files</a>
    <a href="#config">Config</a>
    <a href="#commands">Commands</a>
    <a href="#tech">Tech Stack</a>
    <a href="#troubleshooting">Troubleshooting</a>
  </div>
</section>

<div class="main-content">

  <!-- ── Architecture Diagram ─────────────────────────────────── -->
  <div class="ref-grid" style="grid-template-columns:1fr">
  <div class="ref-section" id="architecture">
    <div class="window-wrap fade-up">
      <div class="window-bar">
        <span class="window-dot dot-red"></span>
        <span class="window-dot dot-yellow"></span>
        <span class="window-dot dot-green"></span>
        <span style="margin-left:10px;font-size:12px;color:var(--muted)">System Architecture — click any component for details</span>
      </div>
      <div class="window-body" style="padding:20px">
        <div class="arch-wrap">

          <!-- diagram -->
          <div>
            <!-- Windows 11 outer box -->
            <div class="arch-box arch-box-windows">
              <div class="arch-box-hdr arch-node arch-clickable" data-aid="windows" style="background:transparent;border:none;border-radius:6px;padding:3px 4px">
                <span class="arch-box-tag" style="color:rgba(160,180,240,0.8)">Windows 11 Pro · host</span>
                <span class="arch-hint">details →</span>
              </div>

              <!-- WSL2 box -->
              <div class="arch-box arch-box-wsl">
                <div class="arch-box-hdr arch-node arch-clickable" data-aid="wsl2" style="background:transparent;border:none;border-radius:6px;padding:3px 4px">
                  <span class="arch-box-tag" style="color:rgba(134,239,172,0.85)">WSL2 Ubuntu-22.04 · systemd</span>
                  <span class="arch-hint">details →</span>
                </div>

                <!-- Docker box -->
                <div class="arch-box arch-box-docker">
                  <div class="arch-box-hdr arch-node arch-clickable" data-aid="docker" style="background:transparent;border:none;border-radius:6px;padding:3px 4px">
                    <span class="arch-box-tag" style="color:rgba(96,165,250,0.85)">Docker Engine 24.0.3</span>
                    <span class="arch-hint">details →</span>
                  </div>
                  <div class="arch-svc-grid">
                    <div class="arch-node arch-clickable" data-aid="nginx">
                      <div class="arch-node-name">atlas-nginx</div>
                      <div class="arch-node-sub" style="color:#60a5fa">:80 — reverse proxy</div>
                    </div>
                    <div class="arch-node arch-clickable" data-aid="webapp">
                      <div class="arch-node-name">atlas-webapp</div>
                      <div class="arch-node-sub" style="color:#60a5fa">:3456 — Express / EJS</div>
                    </div>
                    <div class="arch-node arch-clickable" data-aid="prometheus">
                      <div class="arch-node-name">atlas-prometheus</div>
                      <div class="arch-node-sub" style="color:#60a5fa">:9090 — metrics</div>
                    </div>
                    <div class="arch-node arch-clickable" data-aid="grafana">
                      <div class="arch-node-name">atlas-grafana</div>
                      <div class="arch-node-sub" style="color:#60a5fa">:3000 — dashboards</div>
                    </div>
                  </div>
                </div><!-- /docker -->
              </div><!-- /wsl2 -->

              <!-- host-level services (outside Docker, inside Windows) -->
              <div class="arch-host-row">
                <div class="arch-node arch-clickable" data-aid="claude-code">
                  <div class="arch-node-name">Claude Code</div>
                  <div class="arch-node-sub">CLI / VSCode extension</div>
                </div>
                <div class="arch-node arch-clickable" data-aid="scheduler">
                  <div class="arch-node-name">Task Scheduler</div>
                  <div class="arch-node-sub">Atlas Stack Startup</div>
                </div>
                <div class="arch-node arch-clickable" data-aid="browser">
                  <div class="arch-node-name">Browser</div>
                  <div class="arch-node-sub">localhost:3456</div>
                </div>
              </div>
            </div><!-- /windows -->

            <!-- external row -->
            <div class="arch-ext-row">
              <div class="arch-node arch-clickable" data-aid="claude-api" style="border-color:rgba(232,68,90,.3)">
                <div class="arch-node-name">Claude API</div>
                <div class="arch-node-sub">Anthropic · opus / sonnet / haiku</div>
              </div>
              <div class="arch-node arch-clickable" data-aid="google-mcp" style="border-color:rgba(251,191,36,.3)">
                <div class="arch-node-name">Google Cal / Gmail</div>
                <div class="arch-node-sub">MCP stdio servers</div>
              </div>
              <div class="arch-node arch-clickable" data-aid="data-layer" style="border-color:rgba(134,239,172,.3)">
                <div class="arch-node-name">JSON Data Layer</div>
                <div class="arch-node-sub">data/ · flat files</div>
              </div>
            </div>
          </div><!-- /diagram -->

          <!-- detail panel -->
          <div class="arch-panel" id="arch-detail">
            <div class="arch-panel-hint">← Click any component<br>to see details</div>
          </div>

        </div><!-- /arch-wrap -->
      </div>
    </div>
  </div>
  </div>

  <!-- ── Stack + Directory ─────────────────────────────────────── -->
  <div class="ref-grid">

    <div class="ref-section" id="stack">
      <div class="window-wrap fade-up">
        <div class="window-bar">
          <span class="window-dot dot-red"></span><span class="window-dot dot-yellow"></span><span class="window-dot dot-green"></span>
          <span style="margin-left:10px;font-size:12px;color:var(--muted)">Stack Overview</span>
        </div>
        <div class="window-body" style="padding:20px">
          <table class="ref-table service-row">
            <thead><tr><th>Service</th><th>Container</th><th>Port</th><th>Health endpoint</th></tr></thead>
            <tbody>
              <tr>
                <td>Atlas webapp</td><td><code>atlas-webapp</code></td>
                <td><span class="port-pill">3456</span></td><td><code>/api/health → {"status":"ok"}</code></td>
              </tr>
              <tr>
                <td>Prometheus</td><td><code>atlas-prometheus</code></td>
                <td><span class="port-pill">9090</span></td><td><code>/-/healthy → 200</code></td>
              </tr>
              <tr>
                <td>Grafana</td><td><code>atlas-grafana</code></td>
                <td><span class="port-pill">3000</span></td><td><code>/api/health → 200</code></td>
              </tr>
              <tr>
                <td>nginx</td><td><code>atlas-nginx</code></td>
                <td><span class="port-pill">80</span></td><td><code>bypassed (direct :3456)</code></td>
              </tr>
            </tbody>
          </table>
          <div style="margin-top:18px">
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">Health check commands</div>
            <div class="config-block" style="margin-top:0;font-size:11px"><span class="config-comment"># inspect container health (no curl needed)</span>
MSYS_NO_PATHCONV=1 wsl -d Ubuntu-22.04 -- \
  docker inspect atlas-webapp \
  --format <span class="config-val">'{{.State.Health.Status}}'</span>

<span class="config-comment"># check all containers at once</span>
MSYS_NO_PATHCONV=1 wsl -d Ubuntu-22.04 -- \
  docker ps --format <span class="config-val">"{{.Names}}\t{{.Status}}"</span></div>
          </div>
          <div style="margin-top:18px">
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Auto-start chain</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.9">
              Windows login → <span style="color:var(--text)">Task Scheduler</span> fires<br>
              → <code style="font-size:11px">wsl.exe</code> starts WSL2<br>
              → systemd boots → <code style="font-size:11px">docker.service</code> starts<br>
              → <code style="font-size:11px">atlas-stack.service</code> runs compose up<br>
              → all 4 containers start &amp; accept traffic
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Directory Layout -->
    <div class="ref-section" id="layout">
      <div class="window-wrap fade-up">
        <div class="window-bar">
          <span class="window-dot dot-red"></span><span class="window-dot dot-yellow"></span><span class="window-dot dot-green"></span>
          <span style="margin-left:10px;font-size:12px;color:var(--muted)">Directory Layout</span>
        </div>
        <div class="window-body" style="padding:20px">
          <table class="ref-table">
            <thead><tr><th>Path</th><th>Purpose</th></tr></thead>
            <tbody>
              <tr><td class="path-cell">.claude/agents/</td><td>Subagent definitions (one .md per agent)</td></tr>
              <tr><td class="path-cell">.claude/commands/</td><td>Slash-command skill files</td></tr>
              <tr><td class="path-cell">.claude/rules/</td><td>Path-scoped instruction files</td></tr>
              <tr><td class="path-cell">.claude/settings.json</td><td>Hooks, permissions, env vars</td></tr>
              <tr><td class="path-cell">.mcp.json</td><td>MCP server definitions (Google Cal, Gmail)</td></tr>
              <tr><td class="path-cell">config/</td><td>atlas.yaml, prometheus.yml, grafana/, nginx/</td></tr>
              <tr><td class="path-cell">data/</td><td>All runtime data — JSON flat files</td></tr>
              <tr><td class="path-cell">logs/sessions/</td><td>Per-day session event logs</td></tr>
              <tr><td class="path-cell">logs/errors/</td><td>Error logs</td></tr>
              <tr><td class="path-cell">memory/</td><td>Atlas persistent cross-session memory</td></tr>
              <tr><td class="path-cell">output/</td><td>Final task deliverables</td></tr>
              <tr><td class="path-cell">plans/</td><td>Large task plan files</td></tr>
              <tr><td class="path-cell">prompts/</td><td>System prompts and reusable templates</td></tr>
              <tr><td class="path-cell">tasks/queue/</td><td>Pending tasks (one .md per task)</td></tr>
              <tr><td class="path-cell">tasks/active/</td><td>Currently executing tasks</td></tr>
              <tr><td class="path-cell">tasks/completed/</td><td>Finished tasks</td></tr>
              <tr><td class="path-cell">tasks/failed/</td><td>Failed tasks with error notes</td></tr>
              <tr><td class="path-cell">tools/price-tracker/</td><td>Node.js price scraper CLI</td></tr>
              <tr><td class="path-cell">tools/atlas-webapp/</td><td>Express server + EJS views</td></tr>
              <tr><td class="path-cell">tools/scripts/</td><td>Shell utility scripts</td></tr>
              <tr><td class="path-cell">workflows/</td><td>YAML workflow pipeline definitions</td></tr>
              <tr><td class="path-cell">docker-compose.yml</td><td>Defines all 4 containers and volumes</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>

  <!-- ── API Endpoints ─────────────────────────────────────────── -->
  <div class="ref-grid" style="grid-template-columns:1fr">
  <div class="ref-section" id="api">
    <div class="window-wrap fade-up">
      <div class="window-bar">
        <span class="window-dot dot-red"></span><span class="window-dot dot-yellow"></span><span class="window-dot dot-green"></span>
        <span style="margin-left:10px;font-size:12px;color:var(--muted)">API Endpoints</span>
        <span style="margin-left:auto;font-size:11px;color:var(--muted);padding-right:4px">All routes are unauthenticated · localhost only</span>
      </div>
      <div class="window-body" style="padding:20px">
        <table class="ref-table">
          <thead>
            <tr>
              <th style="width:64px">Method</th><th style="width:260px">Path</th>
              <th>Description</th><th style="width:90px">Response</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><span class="method-badge method-get">GET</span></td><td class="route-path">/</td><td>Morning briefing — goals, todos, chores, price snapshot, health summary</td><td>HTML</td></tr>
            <tr><td><span class="method-badge method-get">GET</span></td><td class="route-path">/prices</td><td>Price dashboard — tracked products, add-product form, active alerts</td><td>HTML</td></tr>
            <tr><td><span class="method-badge method-get">GET</span></td><td class="route-path">/history/:productId</td><td>Price history chart for one product; <code>productId</code> matches slug in products.json</td><td>HTML</td></tr>
            <tr><td><span class="method-badge method-get">GET</span></td><td class="route-path">/compare</td><td>Cross-store comparison — best landed cost per product per store</td><td>HTML</td></tr>
