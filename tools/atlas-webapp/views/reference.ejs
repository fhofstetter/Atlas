document.querySelectorAll('.arch-clickable').forEach(el => {
  el.addEventListener('click', e => {
    e.stopPropagation()
    const id = el.dataset.aid
    const d = ARCH_DATA[id]
    if (!d) return
    document.querySelectorAll('.arch-clickable').forEach(n => n.classList.remove('arch-active'))
    el.classList.add('arch-active')
    const panel = document.getElementById('arch-detail')
    panel.innerHTML =
      '<div class="arch-panel-title">' + d.title + '</div>' +
      '<div class="arch-panel-sub">' + d.sub + '</div>' +
      '<div class="arch-panel-facts">' +
        d.facts.map(function(r){ return '<div class="arch-pf-row"><span class="arch-pf-key">' + r[0] + '</span><span class="arch-pf-val">' + r[1] + '</span></div>' }).join('') +
      '</div>' +
      (d.note ? '<div class="arch-panel-note">' + d.note + '</div>' : '')
  })
})

// fade-up on scroll
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target) } })
}, { threshold: 0.08 })
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el))
</script>

