<%- include('partials/head', {title, includeCharts: false}) %>
<%- include('partials/nav', {activeNav}) %>

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-badge">
    <span class="hero-badge-dot"></span>
    Live · Market Research
  </div>
  <h1>Find the best price.</h1>
  <p class="hero-sub">Track products across Swiss and German stores. Includes shipping and customs to CH.</p>
</section>

<div class="main-content">

  <!-- STATS -->
  <div class="stats-grid fade-up" id="statsGrid">
    <div class="stat-block">
      <div class="stat-number" id="statProducts">—</div>
      <div class="stat-label">Products tracked</div>
    </div>
    <div class="stat-block">
      <div class="stat-number" id="statAlerts">—</div>
      <div class="stat-label">Active alerts</div>
    </div>
    <div class="stat-block">
      <div class="stat-number" id="statStores">—</div>
      <div class="stat-label">Stores monitored</div>
    </div>
    <div class="stat-block">
      <div class="stat-number">+2.5%</div>
      <div class="stat-label">Visa/MC spread applied</div>
    </div>
  </div>

  <!-- ADD PRODUCT -->
  <div id="add-product" class="window-wrap fade-up">
    <div class="window-bar">
      <div class="dot dot-red"></div>
      <div class="dot dot-yellow"></div>
      <div class="dot dot-green"></div>
      <div class="window-title">Add Product to Track</div>
    </div>
    <div class="window-body">
      <form id="addForm" autocomplete="off">
        <div class="form-row single">
          <input id="inputUrl" class="cmd-input" type="url" placeholder="Store URL — e.g. https://www.amazon.de/dp/B09XYZ" required>
        </div>
        <div class="form-row">
          <input id="inputName" class="cmd-input" type="text" placeholder="Product name (optional — auto-detected)">
          <select id="inputCategory" class="cmd-input">
            <option value="general">Category: General</option>
            <option value="electronics">Electronics</option>
            <option value="clothing">Clothing</option>
            <option value="footwear">Footwear</option>
          </select>
        </div>
        <div class="form-row">
          <input id="inputWeight" class="cmd-input" type="number" step="0.1" min="0.1" placeholder="Weight in kg (e.g. 0.5)">
          <button type="submit" class="btn btn-primary" id="addBtn">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="#000" stroke-width="2" stroke-linecap="round"/></svg>
            Track Product
          </button>
        </div>
      </form>
      <div id="addStatus" style="margin-top:10px;font-size:13px;color:var(--muted);display:none"></div>
    </div>
  </div>

  <!-- CHECK BUTTON -->
  <div class="fade-up" style="margin-bottom:24px">
    <button class="btn btn-red" id="checkBtn" style="width:100%;padding:14px 24px;font-size:15px;justify-content:center;border-radius:var(--radius)">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.5A6.5 6.5 0 1 0 14.5 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 4.5v3.75l2.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Check All Prices Now
    </button>
  </div>

  <!-- LOG PANEL -->
  <div class="log-panel" id="logPanel"></div>

  <!-- PRODUCTS -->
  <div id="products">
    <div class="section-heading">
      Tracked Products
      <span class="count-badge" id="productCount">0</span>
    </div>
    <div class="products-grid" id="productsGrid">
      <div style="color:var(--muted2);font-size:14px;padding:20px 0">Loading products...</div>
    </div>
  </div>

  <!-- ALERTS -->
  <div id="alerts">
    <div class="section-heading">
      Price Alerts
      <span class="count-badge" id="alertCount">0</span>
    </div>
    <div class="table-wrap" id="alertsWrap">
      <div class="table-empty">Loading alerts...</div>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
