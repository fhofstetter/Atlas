<%- include('partials/head', {title, includeCharts: false}) %>
<%- include('partials/nav', {activeNav}) %>

<section class="hero" style="min-height:20vh">
  <div class="hero-glow"></div>
  <h1>Training</h1>
  <p class="hero-sub">
    <% if (currentPhase) { %>
      Phase <%= currentPhaseNum %>/3 — <%= currentPhase.name %>
    <% } else { %>
      No active training plan
    <% } %>
  </p>
</section>

<div class="main-content">

<% if (!plan || !plan.phases) { %>
  <!-- EMPTY STATE -->
  <div class="window-wrap fade-up">
    <div class="window-body" style="display:flex;align-items:center;gap:20px;padding:32px">
      <div style="font-size:40px">🏋️</div>
      <div>
        <div style="font-weight:600;font-size:15px;color:var(--text);margin-bottom:6px">No training plan yet</div>
        <div style="font-size:13px;color:var(--muted)">Ask Atlas: "Create my training plan" to get started.</div>
      </div>
    </div>
  </div>
<% } else { %>

  <!-- ── STATS STRIP ──────────────────────────────────────────────────────── -->
  <div class="stats-grid fade-up" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px">
    <div class="stat-block">
      <div class="stat-number" style="color:#e8445a">Phase <%= currentPhaseNum %><span style="font-size:16px;color:var(--muted)">/3</span></div>
      <div class="stat-label"><%= currentPhase ? currentPhase.frequency : '—' %></div>
    </div>
    <div class="stat-block">
      <div class="stat-number" style="color:#f59e0b"><%= plan.current_week_label ? plan.current_week_label : 'Week ' + currentWeek %><% if (!plan.current_week_label) { %><span style="font-size:16px;color:var(--muted)">/12</span><% } else { %><span style="font-size:13px;color:var(--muted);margin-left:6px;font-weight:400">· pre-Wk1</span><% } %></div>
      <div class="stat-label"><% if (startDate) { %>Started <%= startDate %><% } else { %>Not started yet<% } %></div>
    </div>
    <div class="stat-block">
      <div class="stat-number" style="color:#6ee7b7"><%= workoutCount %></div>
      <div class="stat-label">Sessions logged</div>
    </div>
    <div class="stat-block">
      <div class="stat-number" style="color:<%= weeksToNextBenchmark <= 1 ? '#e8445a' : '#60a5fa' %>">
        <% if (nextBenchmark) { %><%= weeksToNextBenchmark %>w<% } else { %>Done<% } %>
      </div>
      <div class="stat-label">To benchmark<% if (nextBenchmark) { %> (Wk <%= nextBenchmark %>)<% } %></div>
    </div>
  </div>

  <!-- ── TODAY ─────────────────────────────────────────────────────────────── -->
  <div class="fade-up" style="margin-bottom:32px">
    <div class="section-heading" style="margin-top:0;display:flex;align-items:center;gap:10px">
      Today — <%= todayName %>
      <span class="pill" style="font-size:10px;background:<%= isRestDay ? 'var(--bg3)' : sessionTypeColors.dim %>;color:<%= isRestDay ? 'var(--muted)' : sessionTypeColors.hex %>;border:1px solid <%= isRestDay ? 'var(--border)' : sessionTypeColors.border %>">
        <%= isRestDay ? 'Recovery' : sessionTypeColors.label %>
      </span>
    </div>

    <!-- Grid: rest day = 1fr 2fr (compact rest | full up-next), training = 1fr 1fr (session | detail panel) -->
    <div class="training-today-grid" style="display:grid;grid-template-columns:<%= isRestDay ? '1fr 2fr' : '1fr 1fr' %>;gap:16px;align-items:stretch">

      <% if (isRestDay) { %>
      <!-- REST: compact info card -->
      <div class="window-wrap" style="border-left:3px solid var(--border)">
        <div class="window-body" style="display:flex;align-items:center;gap:16px;padding:24px">
          <div style="font-size:32px;opacity:.7">😴</div>
          <div>
            <div style="font-weight:600;font-size:14px;color:var(--text);margin-bottom:6px">Rest Day</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.7">Recovery is training.<br>Sleep · Mobility · Myofunctional exercises</div>
          </div>
        </div>
      </div>
      <!-- REST: full Up Next card -->
      <% if (nextSession && nextSessionColors) { %>
      <div class="window-wrap" style="border-left:3px solid <%= nextSessionColors.hex %>">
        <div class="window-body" style="padding:0">
          <div style="padding:16px 20px 12px;border-bottom:1px solid var(--border)">
            <div style="font-size:11px;font-weight:600;letter-spacing:.08em;color:<%= nextSessionColors.hex %>;text-transform:uppercase;margin-bottom:3px">Up Next — <%= nextSessionDay %></div>
            <div style="font-size:15px;font-weight:700;color:var(--text);margin-bottom:3px"><%= nextSession.day_label.replace(/\s*\(.*?\)\s*/, '').trim() %></div>
            <div style="font-size:12px;color:var(--muted)"><%= nextSession.focus %></div>
          </div>
          <% if (nextSession.warm_up && nextSession.warm_up.length) { %>
          <div style="padding:10px 20px;border-bottom:1px solid var(--border)">
            <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:6px">Warm-up</div>
            <div style="display:flex;flex-wrap:wrap;gap:5px">
              <% nextSession.warm_up.forEach(w => { %>
              <span style="background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:2px 7px;font-size:11px;color:var(--muted)"><%= w %></span>
              <% }) %>
            </div>
          </div>
          <% } %>
          <% if (nextSession.exercises && nextSession.exercises.length) { %>
          <div style="padding:10px 20px 14px">
            <% nextSession.exercises.forEach((ex, i) => { %>
            <div style="display:flex;justify-content:space-between;align-items:baseline;padding:5px 0;border-bottom:1px solid var(--border)">
              <span style="font-size:12px;color:var(--text)"><%= ex.name %></span>
              <span style="font-size:11px;color:var(--muted);white-space:nowrap;margin-left:8px"><%= ex.sets %>×<%= ex.reps %><% if (ex.weight_kg !== 'bodyweight' && ex.weight_kg !== 'bag') { %> @ <%= ex.weight_kg %>kg<% } %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <% } else { %>
      <!-- TRAINING: session card -->
      <div data-scope="today">
        <div class="window-wrap" style="border-left:3px solid <%= sessionTypeColors.hex %>;height:100%">
          <div class="window-body" style="padding:0">
            <div style="padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;gap:16px">
              <div>
                <div style="font-size:11px;font-weight:600;letter-spacing:.08em;color:<%= sessionTypeColors.hex %>;text-transform:uppercase;margin-bottom:4px">
                  Phase <%= currentPhaseNum %> · <%= plan.current_week_label ? plan.current_week_label : 'Week ' + currentWeek %>
                </div>
                <div style="font-size:17px;font-weight:700;color:var(--text);margin-bottom:4px"><%= todaySession.day_label %></div>
                <div style="font-size:13px;color:var(--muted)"><%= todaySession.focus %></div>
              </div>
              <span class="pill" style="font-size:10px;white-space:nowrap;margin-top:4px;background:<%= sessionTypeColors.dim %>;color:<%= sessionTypeColors.hex %>;border:1px solid <%= sessionTypeColors.border %>">Today</span>
            </div>
            <% if (todaySession.warm_up && todaySession.warm_up.length) { %>
            <div style="padding:14px 24px;border-bottom:1px solid var(--border)">
              <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Warm-up</div>
              <div style="display:flex;flex-wrap:wrap;gap:6px">
                <% todaySession.warm_up.forEach(w => { %>
                <span style="background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:3px 8px;font-size:12px;color:var(--muted)"><%= w %></span>
                <% }) %>
              </div>
            </div>
            <% } %>
            <% if (todaySession.exercises && todaySession.exercises.length) { %>
            <div style="padding:0 24px 4px">
              <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);padding:14px 0 10px">Exercises</div>
              <% todaySession.exercises.forEach((ex, i) => { %>
              <div style="padding:12px 0;border-top:<%= i > 0 ? '1px solid var(--border)' : 'none' %>;display:grid;grid-template-columns:1fr auto;gap:12px;align-items:start">
                <div>
                  <div style="font-weight:600;font-size:14px;color:var(--text);margin-bottom:4px">
                    <span class="ex-clickable" data-ex="<%- ex.name %>" onclick="showExerciseDetail('today', this.dataset.ex)" title="Click for details"><%= ex.name %></span>
                  </div>
                  <% if (ex.warm_up_sets && ex.warm_up_sets.length) { %>
                  <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Warm-up: <%= ex.warm_up_sets.join(' → ') %></div>
                  <% } %>
                  <% if (ex.cues) { %>
                  <div style="font-size:12px;color:#60a5fa;font-style:italic"><%= ex.cues %></div>
                  <% } %>
                </div>
                <div style="text-align:right;white-space:nowrap">
                  <div style="font-size:14px;font-weight:700;color:var(--text)"><%= ex.sets %>×<%= ex.reps %></div>
                  <div style="font-size:12px;color:var(--muted)"><%= ex.weight_kg === 'bodyweight' || ex.weight_kg === 'bag' ? ex.weight_kg : ex.weight_kg + 'kg' %></div>
                </div>
              </div>
              <% }) %>
            </div>
            <% } %>
            <% if (todaySession.cardio) { %>
            <div style="margin:0 24px 16px;padding:14px;background:rgba(96,165,250,0.06);border:1px solid rgba(96,165,250,0.15);border-radius:var(--radius)">
              <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#60a5fa;margin-bottom:6px">Cardio</div>
              <div style="font-size:13px;color:var(--text);margin-bottom:4px"><%= todaySession.cardio.type %><% if (todaySession.cardio.duration_min) { %> · <%= todaySession.cardio.duration_min %> min<% } %></div>
              <% if (todaySession.cardio.intensity) { %><div style="font-size:12px;color:var(--muted)">Intensity: <%= todaySession.cardio.intensity %></div><% } %>
              <% if (todaySession.cardio.asthma_note) { %><div style="font-size:12px;color:#f59e0b;margin-top:4px">⚠ <%= todaySession.cardio.asthma_note %></div><% } %>
            </div>
            <% } %>
            <% if (todaySession.cool_down && todaySession.cool_down.length) { %>
            <div style="padding:0 24px 16px">
              <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Cool-down</div>
              <div style="display:flex;flex-wrap:wrap;gap:6px">
                <% todaySession.cool_down.forEach(c => { %>
                <span style="background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:3px 8px;font-size:12px;color:var(--muted)"><%= c %></span>
                <% }) %>
              </div>
            </div>
            <% } %>
            <% if (todaySession.notes) { %>
            <div style="margin:0 24px 16px;padding:10px 14px;background:var(--bg3);border-radius:var(--radius);font-size:12px;color:var(--muted);border-left:2px solid var(--border)"><%= todaySession.notes %></div>
            <% } %>
            <% if (nextSession && nextSessionColors) { %>
            <div style="margin:0 24px 16px;padding:10px 14px;background:<%= nextSessionColors.dim %>;border:1px solid <%= nextSessionColors.border %>;border-radius:var(--radius)">
              <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:4px">Up Next — <%= nextSessionDay %></div>
              <div style="font-size:13px;font-weight:600;color:var(--text)"><%= nextSession.day_label.replace(/\s*\(.*?\)\s*/, '').trim() %></div>
              <div style="font-size:12px;color:var(--muted)"><%= nextSession.focus %></div>
            </div>
            <% } %>
          </div>
        </div>
      </div>
      <!-- TRAINING: exercise detail panel -->
      <%- include('partials/exercise-detail-panel', { panelId: 'today' }) %>
      <% } %>

    </div><!-- end today grid -->
  </div><!-- end today section -->

  <!-- ── TRAINING WEEK STRIP ──────────────────────────────────────────────── -->
  <% if (trainingWeekStrip) { %>
  <div class="section-heading fade-up" style="display:flex;align-items:baseline;gap:10px">
    Week <%= trainingWeekStrip.weekNum %> Schedule
    <span style="font-size:12px;font-weight:400;color:var(--muted)">
      <%= trainingWeekStrip.days[0].dayNum %> – <%= trainingWeekStrip.days[6].dayNum %> <%= trainingWeekStrip.days[6].monthName %>
    </span>
    <a href="/calendar" style="margin-left:auto;font-size:11px;color:var(--muted);text-decoration:none;border:1px solid var(--border);padding:3px 9px;border-radius:6px;white-space:nowrap">Full calendar →</a>
  </div>
  <div class="training-week-strip fade-up" style="margin-bottom:32px"><div style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px">
    <% trainingWeekStrip.days.forEach(day => { %>
    <% const hasSession = !!day.session %>
    <% const dayColor = hasSession ? day.session.color : 'var(--muted)' %>
    <% const dayBorder = hasSession ? day.session.colorBorder : 'var(--border)' %>
    <% const dayDim = hasSession ? day.session.colorDim : 'transparent' %>
    <% const tag = `<a href="#${day.session && day.session.anchorId || ''}" style="text-decoration:none;display:block">` %>
    <div style="
      background:<%= day.isToday ? dayDim : 'var(--bg2)' %>;
      border:1px solid <%= day.isToday ? dayBorder : hasSession ? dayBorder : 'var(--border)' %>;
      border-radius:var(--radius);padding:10px 8px;text-align:center;position:relative;
      <%= hasSession ? 'cursor:pointer' : '' %>
    " <%= hasSession ? `onclick="window.location.hash='${day.session.anchorId}'"` : '' %>>
      <div style="font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:<%= day.isToday ? dayColor : hasSession ? dayColor : 'var(--muted)' %>;margin-bottom:4px"><%= day.dayName %></div>
      <div style="font-size:18px;font-weight:700;color:<%= day.isToday ? 'var(--text)' : hasSession ? 'var(--text)' : 'var(--muted)' %>;margin-bottom:8px;line-height:1"><%= day.dayNum %></div>
      <% if (hasSession) { %>
      <div style="background:<%= dayDim %>;border:1px solid <%= dayBorder %>;border-radius:6px;padding:4px 5px">
        <div style="font-size:10px;font-weight:700;color:<%= dayColor %>;line-height:1.3;word-break:break-word"><%= day.session.label %></div>
      </div>
      <% } else { %>
      <div style="font-size:11px;color:var(--muted)">—</div>
      <% } %>
      <% if (day.isToday) { %>
      <div style="position:absolute;top:6px;right:6px;width:6px;height:6px;border-radius:50%;background:<%= dayColor %>"></div>
      <% } %>
    </div>
    <% }) %>
  </div></div><!-- end week strip scroll wrapper -->
  <% } %>

  <!-- ── WEEKLY PROGRESS ──────────────────────────────────────────────────────── -->
  <div class="section-heading fade-up">This Week</div>
  <div class="window-wrap fade-up" style="margin-bottom:32px">
    <div class="window-body" style="padding:0">

      <!-- Stats bar -->
      <div style="display:flex;align-items:stretch;border-bottom:1px solid var(--border);flex-wrap:wrap">

        <!-- Streak -->
        <div style="padding:14px 20px;border-right:1px solid var(--border);display:flex;align-items:center;gap:10px;min-width:110px">
          <span style="font-size:22px"><%= weeklyProgress.streak > 0 ? '🔥' : '💤' %></span>
          <div>
            <div style="font-size:20px;font-weight:700;color:<%= weeklyProgress.streak > 0 ? '#f59e0b' : 'var(--muted)' %>"><%= weeklyProgress.streak %></div>
            <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">day streak</div>
          </div>
        </div>

        <!-- Session pills -->
        <div style="padding:14px 20px;border-right:1px solid var(--border);display:flex;align-items:center;gap:12px">
          <% weeklyProgress.dayPills.forEach(pill => { %>
          <div style="text-align:center">
            <div style="font-size:18px;line-height:1"><%= pill.done ? '✅' : '⬜' %></div>
            <div style="font-size:10px;color:var(--muted);margin-top:3px;font-weight:600"><%= pill.day.toUpperCase() %></div>
          </div>
          <% }) %>
        </div>

        <!-- Session count -->
        <div style="padding:14px 20px;border-right:1px solid var(--border);display:flex;flex-direction:column;justify-content:center">
          <div style="font-size:20px;font-weight:700;color:<%= weeklyProgress.weekSessionsDone >= weeklyProgress.weekSessionsPlanned && weeklyProgress.weekSessionsPlanned > 0 ? '#6ee7b7' : 'var(--text)' %>">
            <%= weeklyProgress.weekSessionsDone %>/<%= weeklyProgress.weekSessionsPlanned %>
          </div>
          <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">sessions</div>
        </div>

        <!-- Muscle coverage bar -->
        <div style="padding:14px 20px;border-right:1px solid var(--border);flex:1;min-width:160px;display:flex;flex-direction:column;justify-content:center">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
            <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">Muscle coverage</div>
            <div style="font-size:13px;font-weight:700;color:var(--text)"><%= weeklyProgress.coveragePct %>%</div>
          </div>
          <div style="height:5px;background:var(--border);border-radius:3px;overflow:hidden">
            <div class="progress-fill-red" style="height:100%;width:<%= weeklyProgress.coveragePct %>%;border-radius:3px"></div>
          </div>
        </div>

        <!-- Phase progress bar -->
        <div style="padding:14px 20px;flex:1;min-width:160px;display:flex;flex-direction:column;justify-content:center">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
            <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">Phase <%= currentPhaseNum %></div>
            <div style="font-size:13px;font-weight:700;color:#f59e0b">Wk <%= weeklyProgress.currentWeek %>/<%= weeklyProgress.phaseWeeks %></div>
          </div>
          <div style="height:5px;background:var(--border);border-radius:3px;overflow:hidden">
            <div class="progress-fill-amber" style="height:100%;width:<%= weeklyProgress.phaseProgressPct %>%;border-radius:3px"></div>
          </div>
        </div>

      </div><!-- end stats bar -->

      <!-- Body diagrams row -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">

        <!-- Worked this week -->
        <div style="padding:18px 20px;border-right:1px solid var(--border)">
          <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:14px">
            Worked this week
            <% if (weeklyProgress.weekSessionsDone === 0) { %>
            <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;margin-left:8px;font-size:11px">— log a session to see progress</span>
            <% } %>
          </div>
          <div style="display:flex;gap:16px;align-items:flex-start">
            <div style="display:flex;gap:8px">
              <div class="ex-diagram-col"><div class="ex-diagram-label">Front</div><div id="weekly-worked-front" class="body-chart-wrap"></div></div>
              <div class="ex-diagram-col"><div class="ex-diagram-label">Back</div><div id="weekly-worked-back" class="body-chart-wrap"></div></div>
            </div>
            <div style="flex:1;padding-top:4px">
              <% if (weeklyProgress.weekSessionsDone > 0) { %>
                <% Object.entries(weeklyProgress.muscleHits).sort((a,b)=>b[1]-a[1]).forEach(([m,c]) => { %>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border)">
                  <span style="font-size:11px;color:var(--text);text-transform:capitalize"><%= m %></span>
                  <span style="font-size:11px;color:#e8445a;font-weight:700"><%= c %>×</span>
                </div>
                <% }) %>
              <% } else { %>
                <div style="font-size:12px;color:var(--muted);line-height:1.7">
                  Complete a session and log it to fill this in.
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Full week target -->
        <div style="padding:18px 20px">
          <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:14px">
            Full week target
          </div>
          <div style="display:flex;gap:16px;align-items:flex-start">
            <div style="display:flex;gap:8px">
              <div class="ex-diagram-col"><div class="ex-diagram-label">Front</div><div id="weekly-plan-front" class="body-chart-wrap"></div></div>
              <div class="ex-diagram-col"><div class="ex-diagram-label">Back</div><div id="weekly-plan-back" class="body-chart-wrap"></div></div>
            </div>
            <div style="flex:1;padding-top:4px">
              <% Object.keys(weeklyProgress.planMuscles).sort().forEach(m => { %>
              <div style="display:flex;align-items:center;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border)">
                <span style="font-size:11px;color:var(--text);text-transform:capitalize"><%= m %></span>
                <% if (weeklyProgress.muscleHits[m]) { %>
                <span style="font-size:11px;color:#6ee7b7;font-weight:700">✓</span>
                <% } else { %>
                <span style="font-size:11px;color:var(--muted)">○</span>
                <% } %>
              </div>
              <% }) %>
            </div>
          </div>
        </div>

      </div><!-- end body diagrams row -->

      <!-- Week complete banner -->
      <% if (weeklyProgress.weekSessionsDone >= weeklyProgress.weekSessionsPlanned && weeklyProgress.weekSessionsPlanned > 0) { %>
      <div style="padding:14px 20px;background:rgba(110,231,183,0.08);border-top:1px solid rgba(110,231,183,0.2);text-align:center">
        <span style="font-size:14px;font-weight:700;color:#6ee7b7">⭐ Week Complete!</span>
        <span style="font-size:12px;color:var(--muted);margin-left:12px">All <%= weeklyProgress.weekSessionsPlanned %> sessions logged. Great work.</span>
      </div>
      <% } %>

    </div>
  </div><!-- end weekly progress -->

  <!-- ── MILITARY BENCHMARKS ────────────────────────────────────────────────── -->
  <div class="training-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px">

    <!-- Benchmarks table -->
    <div>
      <div class="section-heading fade-up">Military Readiness Benchmarks</div>
      <% if (militaryGoal && militaryGoal.benchmarks && militaryGoal.benchmarks.length) { %>
      <div class="table-wrap fade-up">
        <table>
          <thead><tr><th>Test</th><th>Target</th><th>Current</th></tr></thead>
          <tbody>
            <% militaryGoal.benchmarks.forEach(b => { %>
            <tr>
              <td class="cell-strong"><%= b.name %></td>
              <td style="color:#6ee7b7;font-weight:600"><%= b.target %></td>
              <td>
                <% if (!b.current || b.current === 'unknown') { %>
                <span class="pill" style="font-size:10px;background:var(--bg3);color:var(--muted)">not tested</span>
                <% } else { %>
                <span class="cell-strong"><%= b.current %></span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (nextBenchmark) { %>
      <div style="font-size:12px;color:var(--muted);margin-top:8px">
        Next test: Week <%= nextBenchmark %> (<%= weeksToNextBenchmark %> week<%= weeksToNextBenchmark !== 1 ? 's' : '' %> away)
      </div>
      <% } %>
      <% } else { %>
      <div class="window-wrap fade-up"><div class="window-body" style="padding:20px;font-size:13px;color:var(--muted)">No benchmarks set.</div></div>
      <% } %>
    </div>

    <!-- Safety rules -->
    <div>
      <div class="section-heading fade-up">Safety Rules</div>
      <div class="window-wrap fade-up">
        <div class="window-body" style="padding:16px 20px">
          <div style="margin-bottom:12px">
            <div style="font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#f59e0b;margin-bottom:6px">Asthma Protocol</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.6"><%= plan.profile && plan.profile.medical ? plan.profile.medical.asthma_protocol : 'Conversational pace only in Phase 1' %></div>
          </div>
          <div style="border-top:1px solid var(--border);padding-top:12px">
            <div style="font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#e8445a;margin-bottom:6px">Back Safety</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.6"><%= plan.profile && plan.profile.medical ? plan.profile.medical.back_protocol : 'Warm-up sets required on all compounds' %></div>
          </div>
          <% if (plan.profile && plan.profile.adjustment_rules) { %>
          <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:0">
            <div style="font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#60a5fa;margin-bottom:6px">Adaptive Rules</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.8">
              <div>🚴 Biking: <%= plan.profile.adjustment_rules.biking_logged %></div>
              <div>🏊 Swimming: <%= plan.profile.adjustment_rules.swimming_logged %></div>
              <div>🏃 Running: <%= plan.profile.adjustment_rules.running_logged %></div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>

  <!-- ── PHASE ROADMAP ──────────────────────────────────────────────────────── -->
  <div class="section-heading fade-up">12-Week Roadmap</div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px" class="fade-up">
    <% phases.forEach(phase => {
      const isPast = phase.phase < currentPhaseNum
      const isCurrent = phase.phase === currentPhaseNum
      const isFuture = phase.phase > currentPhaseNum
      const borderColor = isCurrent ? '#e8445a' : isPast ? '#6ee7b7' : 'var(--border)'
      const opacity = isFuture ? '0.65' : '1'
    %>
    <div id="phase-card-<%= phase.phase %>" onclick="previewPhase(<%= phase.phase %>)" style="background:var(--bg2);border:1px solid <%= borderColor %>;border-radius:var(--radius);padding:18px;opacity:<%= opacity %>;cursor:pointer;transition:border-color .15s,opacity .15s,box-shadow .15s">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:<%= isCurrent ? '#e8445a' : isPast ? '#6ee7b7' : 'var(--muted)' %>">
          Phase <%= phase.phase %> · Wk <%= phase.weeks %>
        </div>
        <% if (isCurrent) { %>
        <span class="pill pill-red" style="font-size:9px">Active</span>
        <% } else if (isPast) { %>
        <span class="pill pill-green" style="font-size:9px">Done</span>
        <% } %>
      </div>
      <div style="font-size:13px;font-weight:600;color:var(--text);margin-bottom:6px"><%= phase.name %></div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:8px"><%= phase.focus %></div>
      <div style="font-size:11px;color:var(--muted)"><%= phase.frequency %> · <%= (phase.sessions_per_week || []).length %> session type<%= (phase.sessions_per_week || []).length !== 1 ? 's' : '' %></div>
    </div>
    <% }) %>
  </div>

  <!-- ── CURRENT PHASE SESSIONS ─────────────────────────────────────────────── -->
  <div id="current-phase-sessions-wrap">
  <% if (sessions.length) { %>
  <div class="section-heading fade-up">Phase <%= currentPhaseNum %> Sessions</div>
  <div class="training-2col fade-up" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;align-items:stretch">
    <div data-scope="phase" style="display:flex;flex-direction:column;gap:16px">
      <% sessions.forEach(session => {
        const isToday = todaySession && session.day_label === todaySession.day_label
        const sType = session.day_label.toLowerCase().includes('push') ? 'push' : session.day_label.toLowerCase().includes('pull') ? 'pull' : 'lower'
        const sColor = { push: '#3b82f6', pull: '#8b5cf6', lower: '#10b981' }[sType] || '#e8445a'
        const sDim   = { push: 'rgba(59,130,246,0.12)', pull: 'rgba(139,92,246,0.12)', lower: 'rgba(16,185,129,0.12)' }[sType] || 'rgba(232,68,90,0.08)'
        const anchorId = 'session-' + sType
      %>
      <div id="<%= anchorId %>" class="window-wrap" style="border-left:3px solid <%= isToday ? sColor : 'transparent' %>;scroll-margin-top:80px">
        <div class="window-body" style="padding:0">
          <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;background:<%= isToday ? sDim : 'transparent' %>">
            <div>
              <div style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px"><%= session.day_label %></div>
              <div style="font-size:12px;color:var(--muted)"><%= session.focus %></div>
            </div>
            <% if (isToday) { %><span class="pill" style="font-size:9px;background:<%= sDim %>;color:<%= sColor %>;border:1px solid rgba(0,0,0,0.15)">Today</span><% } %>
          </div>
          <% if (session.warm_up && session.warm_up.length) { %>
          <div style="padding:8px 18px;border-bottom:1px solid var(--border)">
            <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:6px">Warm-up</div>
            <div style="display:flex;flex-wrap:wrap;gap:5px">
              <% session.warm_up.forEach(w => { %>
              <span style="background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:2px 7px;font-size:11px;color:var(--muted)"><%= w %></span>
              <% }) %>
            </div>
          </div>
          <% } %>
          <% if (session.exercises && session.exercises.length) { %>
          <div style="padding:10px 18px">
            <% session.exercises.forEach(ex => { %>
            <div style="display:flex;justify-content:space-between;align-items:baseline;padding:4px 0;border-bottom:1px solid var(--border)">
              <span class="ex-clickable" style="font-size:12px;color:var(--text)" data-ex="<%- ex.name %>" onclick="showExerciseDetail('phase', this.dataset.ex)" title="Click for details"><%= ex.name %></span>
              <span style="font-size:12px;color:var(--muted);white-space:nowrap;margin-left:8px"><%= ex.sets %>×<%= ex.reps %> <% if (ex.weight_kg !== 'bodyweight' && ex.weight_kg !== 'bag') { %>@ <%= ex.weight_kg %>kg<% } else { %>(<%= ex.weight_kg %>)<% } %></span>
            </div>
            <% }) %>
          </div>
          <% } %>
          <% if (session.cardio) { %>
          <div style="padding:8px 18px;background:rgba(96,165,250,0.05)">
            <span style="font-size:11px;color:#60a5fa;font-weight:600">Cardio: </span>
            <span style="font-size:11px;color:var(--muted)"><%= session.cardio.type %><% if (session.cardio.duration_min) { %> · <%= session.cardio.duration_min %> min<% } %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <%- include('partials/exercise-detail-panel', { panelId: 'phase' }) %>
  </div>
  <% } %>
  </div><!-- end current-phase-sessions-wrap -->

  <!-- ── PHASE PREVIEW ──────────────────────────────────────────────────────── -->
  <div id="phase-preview-wrap" style="display:none">
    <div class="section-heading fade-up" id="phase-preview-heading"></div>
    <div class="training-2col fade-up" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;align-items:stretch">
      <div id="phase-preview-cards" style="display:flex;flex-direction:column;gap:16px"></div>
      <%- include('partials/exercise-detail-panel', { panelId: 'preview' }) %>
    </div>
  </div>

  <!-- ── RECENT WORKOUTS ────────────────────────────────────────────────────── -->
  <% if (recentWorkouts && recentWorkouts.length) { %>
  <div class="section-heading fade-up">Recent Logged Sessions</div>
  <div class="table-wrap fade-up" style="margin-bottom:32px">
    <table>
      <thead><tr><th>Date</th><th>Type</th><th>Duration</th><th>Notes</th></tr></thead>
      <tbody>
        <% recentWorkouts.forEach(w => { %>
        <tr>
          <td class="cell-muted"><%= w.date || '—' %></td>
          <td><span class="pill pill-green" style="font-size:10px"><%= w.type || '—' %></span></td>
          <td class="cell-muted"><%= w.duration_min ? w.duration_min + ' min' : '—' %></td>
          <td class="cell-muted" style="font-size:12px"><%= w.notes || '' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <!-- ── HOW TO USE ─────────────────────────────────────────────────────────── -->
  <div class="window-wrap fade-up" style="margin-bottom:32px">
    <div class="window-body" style="padding:18px 22px">
      <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:12px">How to use Atlas Training</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <% [
          ['What should I train today?', 'personal-trainer reads plan + logs'],
          ['Log workout: bench 3×6 @ 70kg', 'health-agent logs it'],
          ['I went biking for 45 min', 'logs it, plan adjusts next session'],
          ['Run benchmark test', 'personal-trainer records current scores'],
          ['Adjust plan — traveling this week', 'personal-trainer rewrites that week'],
          ['How is my asthma doing with cardio?', 'health-agent reviews breathing notes'],
        ].forEach(([cmd, desc]) => { %>
        <div style="background:var(--bg3);border-radius:var(--radius);padding:8px 12px">
          <div style="font-size:12px;color:var(--text);font-family:monospace;margin-bottom:2px">"<%= cmd %>"</div>
          <div style="font-size:11px;color:var(--muted)"><%= desc %></div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;font-size:12px;color:var(--muted);margin-bottom:32px">
    🔒 All training data is stored locally — never sent to external services.
  </div>

<% } %>

  <div style="display:flex;gap:12px">
    <a href="/health" class="btn btn-ghost">← Health</a>
    <a href="/" class="btn btn-ghost">Overview</a>
  </div>

</div>

<script src="https://unpkg.com/body-muscles@latest/dist/umd/body-muscles.umd.min.js"></script>
<script src="/js/body-highlighter.browser.js"></script>
<script src="/js/exercise-modal.js"></script>
<script>
  initExerciseModal(<%- JSON.stringify(exerciseLibrary) %>)

  const _allPhases = <%- JSON.stringify(phases) %>
  const _currentPhaseNum = <%= currentPhaseNum %>

  function _sessionColor(label) {
    const l = label.toLowerCase()
    if (l.includes('push') || l.includes('upper') || l.includes('strength')) return { hex: '#3b82f6', dim: 'rgba(59,130,246,0.1)' }
    if (l.includes('pull') || l.includes('combat')) return { hex: '#8b5cf6', dim: 'rgba(139,92,246,0.1)' }
    if (l.includes('lower') || l.includes('conditioning')) return { hex: '#10b981', dim: 'rgba(16,185,129,0.1)' }
    return { hex: '#e8445a', dim: 'rgba(232,68,90,0.08)' }
  }

  function previewPhase(n) {
    const currentWrap = document.getElementById('current-phase-sessions-wrap')
    const previewWrap = document.getElementById('phase-preview-wrap')

    _allPhases.forEach(p => {
      const card = document.getElementById('phase-card-' + p.phase)
      if (!card) return
      const sel = p.phase === n
      const cur = p.phase === _currentPhaseNum
      const past = p.phase < _currentPhaseNum
      card.style.borderColor = sel ? '#60a5fa' : cur ? '#e8445a' : past ? '#6ee7b7' : 'var(--border)'
      card.style.opacity = sel ? '1' : p.phase > _currentPhaseNum ? '0.65' : '1'
      card.style.boxShadow = sel ? '0 0 0 2px rgba(96,165,250,0.2)' : ''
    })

    if (n === _currentPhaseNum) {
      previewWrap.style.display = 'none'
      currentWrap.style.display = ''
      currentWrap.scrollIntoView({ behavior: 'smooth', block: 'start' })
      return
    }

    const phase = _allPhases.find(p => p.phase === n)
    if (!phase) return

    currentWrap.style.display = 'none'
    document.getElementById('phase-preview-heading').textContent = `Phase ${n} — ${phase.name}`

    const body = document.getElementById('phase-preview-cards')
    body.innerHTML = ''

    ;(phase.sessions_per_week || []).forEach(session => {
      const { hex: color, dim } = _sessionColor(session.day_label)
      const exRows = (session.exercises || []).map(ex => {
        const wt = ex.weight_kg === 'bodyweight' || ex.weight_kg === 'bag' ? `(${ex.weight_kg})` : `@ ${ex.weight_kg}kg`
        const safe = ex.name.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
        return `<div style="display:flex;justify-content:space-between;align-items:baseline;padding:4px 0;border-bottom:1px solid var(--border)">
          <span class="ex-clickable" style="font-size:12px;color:var(--text)" data-ex="${safe}" onclick="showExerciseDetail('preview',this.dataset.ex)" title="Click for details">${ex.name}</span>
          <span style="font-size:12px;color:var(--muted);white-space:nowrap;margin-left:8px">${ex.sets}×${ex.reps} ${wt}</span>
        </div>`
      }).join('')
      const warmUpHtml = (session.warm_up && session.warm_up.length) ? `<div style="padding:8px 18px;border-bottom:1px solid var(--border)">
        <div style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:6px">Warm-up</div>
        <div style="display:flex;flex-wrap:wrap;gap:5px">${session.warm_up.map(w => `<span style="background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:2px 7px;font-size:11px;color:var(--muted)">${w}</span>`).join('')}</div>
      </div>` : ''
      const cardioHtml = session.cardio ? `<div style="padding:8px 18px;background:rgba(96,165,250,0.05)">
        <span style="font-size:11px;color:#60a5fa;font-weight:600">Cardio: </span>
        <span style="font-size:11px;color:var(--muted)">${session.cardio.type}${session.cardio.duration_min ? ' · ' + session.cardio.duration_min + ' min' : ''}</span>
      </div>` : ''
      const el = document.createElement('div')
      el.className = 'window-wrap'
      el.style.cssText = `border-left:3px solid ${color}`
      el.innerHTML = `<div class="window-body" style="padding:0">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;background:${dim}">
          <div>
            <div style="font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px">${session.day_label}</div>
            <div style="font-size:12px;color:var(--muted)">${session.focus || ''}</div>
          </div>
        </div>
        ${warmUpHtml}
        ${exRows ? `<div style="padding:10px 18px">${exRows}</div>` : ''}
        ${cardioHtml}
      </div>`
      body.appendChild(el)
    })

    previewWrap.style.display = ''
    previewWrap.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  // Weekly diagrams — render once on load
  const _muscleHits = <%- JSON.stringify(weeklyProgress.muscleHits) %>
  const _planMuscles = <%- JSON.stringify(weeklyProgress.planMuscles) %>
  // Convert planMuscles to a uniform-intensity hit map (color = blue for target)
  const _planHitMap = Object.fromEntries(Object.keys(_planMuscles).map(m => [m, 1]))
  document.addEventListener('DOMContentLoaded', () => {
    renderWeeklyDiagram('weekly-worked-front', 'weekly-worked-back', _muscleHits, '#17bba5')
    renderWeeklyDiagram('weekly-plan-front',   'weekly-plan-back',   _planHitMap,  '#0e7a6e')
  })
</script>
<%- include('partials/footer') %>
