<%- include('partials/head', {title: 'Maintenance', includeCharts: false}) %>
<style>
  body { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
  .maint-wrap { text-align: center; max-width: 480px; padding: 40px 24px; }
  .maint-icon {
    width: 56px; height: 56px; margin: 0 auto 28px;
    border-radius: 50%;
    background: rgba(232,68,90,0.12);
    border: 1px solid rgba(232,68,90,0.3);
    display: flex; align-items: center; justify-content: center;
  }
  .maint-icon svg { width: 26px; height: 26px; color: var(--red2); }
  .maint-title { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 12px; }
  .maint-reason {
    font-size: 14px; color: var(--muted); line-height: 1.7;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 14px 18px; margin: 20px 0 28px;
    text-align: left;
  }
  .maint-refresh { font-size: 12px; color: var(--muted2); }
  .maint-countdown { color: var(--muted); font-weight: 600; }
  .pulse {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: var(--red); margin-right: 8px;
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }
</style>

<div class="maint-wrap">
  <div class="maint-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>
  </div>
  <div style="font-size:12px;font-weight:600;letter-spacing:1px;color:var(--muted);text-transform:uppercase;margin-bottom:10px">
    <span class="pulse"></span>Atlas
  </div>
  <div class="maint-title">Down for maintenance</div>
  <p style="color:var(--muted);font-size:14px">We'll be right back. This usually takes less than a minute.</p>
  <% if (reason) { %>
  <div class="maint-reason"><%= reason %></div>
  <% } %>
  <div class="maint-refresh">
    Checking again in <span class="maint-countdown" id="cd">30</span>s
  </div>
</div>

<script>
  let t = 30
  const el = document.getElementById('cd')
  const iv = setInterval(() => {
    t--
    el.textContent = t
    if (t <= 0) { clearInterval(iv); location.reload() }
  }, 1000)
</script>
</body>
</html>
