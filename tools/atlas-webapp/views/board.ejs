<%- include('partials/head', {title, includeCharts: false}) %>
<%- include('partials/nav', {activeNav}) %>

<section class="hero" style="min-height:14vh">
  <div class="hero-glow"></div>
  <h1>Board</h1>
  <p class="hero-sub">
    <% if (hasToken) { %>
      <%= totalOpen %> open issues across <%= repos.length %> repos
    <% } else { %>
      Set GITHUB_TOKEN in .env to enable
    <% } %>
  </p>
</section>

<% if (!hasToken) { %>
<div class="main-content">
  <div class="window-wrap fade-up">
    <div class="window-body" style="padding:28px;display:flex;gap:20px;align-items:center">
      <div style="font-size:36px">🔑</div>
      <div>
        <div style="font-weight:600;font-size:15px;color:var(--text);margin-bottom:6px">GitHub token not configured</div>
        <div style="font-size:13px;color:var(--muted)">Add <code>GITHUB_TOKEN=ghp_...</code> to your <code>.env</code> file and restart the stack.</div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
<% return %>
<% } %>

<%
const COLS = [
  { key: 'backlog',    label: 'Backlog',     color: '#6b7280', dot: '#4b5563' },
  { key: 'ready',     label: 'Ready',        color: '#10b981', dot: '#059669' },
  { key: 'inProgress',label: 'In Progress',  color: '#f59e0b', dot: '#d97706' },
  { key: 'inReview',  label: 'In Review',    color: '#60a5fa', dot: '#3b82f6' },
  { key: 'blocked',   label: 'Blocked',      color: '#e8445a', dot: '#c73050' },
  { key: 'done',      label: 'Done (14d)',   color: '#6ee7b7', dot: '#10b981' },
]

const TYPE_COLORS = {
  feat:     '#0075ca', fix:      '#d73a4a', chore:    '#b5ad23',
  refactor: '#7057ff', docs:     '#0052cc', security: '#b60205', research: '#5cbfcf',
}
const PRIO_COLORS = {
  'P0: critical': '#b60205', 'P1: high': '#d93f0b',
  'P2: medium':   '#c0a080', 'P3: low':  '#b0a090',
}
%>

<div style="padding:0 24px 32px;overflow-x:auto">
  <div style="display:grid;grid-template-columns:repeat(6,minmax(260px,1fr));gap:14px;min-width:1400px">

  <% COLS.forEach(col => {
    const issues = columns[col.key] || []
  %>
  <div>
    <!-- Column header -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;padding:0 4px">
      <span style="width:8px;height:8px;border-radius:50%;background:<%= col.dot %>;flex-shrink:0"></span>
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted)"><%= col.label %></span>
      <span style="margin-left:auto;font-size:11px;color:var(--muted);background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:1px 7px"><%= issues.length %></span>
    </div>

    <!-- Cards -->
    <div style="display:flex;flex-direction:column;gap:8px">
    <% if (!issues.length) { %>
      <div style="border:1px dashed var(--border);border-radius:var(--radius);padding:16px;text-align:center;font-size:12px;color:var(--muted)">Empty</div>
    <% } %>
    <% issues.forEach(issue => {
      const typeColor  = TYPE_COLORS[issue.typeLabel]  || '#888'
      const prioColor  = PRIO_COLORS[issue.priorityLabel] || '#888'
      const repoColors = { 'Atlas': '#e8445a', 'atlas-fit': '#10b981', 'atlas-trading': '#8b5cf6' }
      const repoColor  = repoColors[issue.repo] || '#6b7280'
    %>
    <a href="<%= issue.url %>" target="_blank" rel="noopener" style="text-decoration:none">
      <div class="window-wrap" style="border-left:3px solid <%= typeColor %>;cursor:pointer;transition:border-color .15s,box-shadow .15s" onmouseover="this.style.boxShadow='0 0 0 1px rgba(255,255,255,0.08)'" onmouseout="this.style.boxShadow=''">
        <div class="window-body" style="padding:12px 14px">

          <!-- Repo + number -->
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:7px">
            <span style="font-size:10px;font-weight:700;color:<%= repoColor %>;text-transform:uppercase;letter-spacing:.05em"><%= issue.repo %></span>
            <span style="font-size:10px;color:var(--muted)">#<%= issue.number %></span>
            <% if (issue.milestone) { %>
            <span style="margin-left:auto;font-size:10px;color:var(--muted);background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:1px 6px;white-space:nowrap;max-width:90px;overflow:hidden;text-overflow:ellipsis"><%= issue.milestone %></span>
            <% } %>
          </div>

          <!-- Title -->
          <div style="font-size:13px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:8px"><%= issue.title %></div>

          <!-- Labels row -->
          <div style="display:flex;flex-wrap:wrap;gap:4px">
            <% if (issue.typeLabel) { %>
            <span style="font-size:10px;background:rgba(<%= parseInt(typeColor.slice(1,3),16) %>,<%= parseInt(typeColor.slice(3,5),16) %>,<%= parseInt(typeColor.slice(5,7),16) %>,0.15);color:<%= typeColor %>;border:1px solid <%= typeColor %>33;border-radius:4px;padding:1px 5px"><%= issue.typeLabel %></span>
            <% } %>
            <% if (issue.priorityLabel) { %>
            <span style="font-size:10px;color:<%= prioColor %>;border:1px solid <%= prioColor %>44;border-radius:4px;padding:1px 5px"><%= issue.priorityLabel %></span>
            <% } %>
            <% if (issue.sizeLabel) { %>
            <span style="font-size:10px;color:var(--muted);border:1px solid var(--border);border-radius:4px;padding:1px 5px"><%= issue.sizeLabel %></span>
            <% } %>
          </div>

        </div>
      </div>
    </a>
    <% }) %>
    </div>
  </div>
  <% }) %>

  </div>
</div>

<%- include('partials/footer') %>
