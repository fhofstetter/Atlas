{
  "title": "Atlas Webapp",
  "uid": "atlas-webapp",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Products Tracked",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "atlas_tracked_products_total", "legendFormat": "products", "datasource": "Prometheus" }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "rate(atlas_http_requests_total[1m])", "legendFormat": "{{method}} {{path}} {{status}}", "datasource": "Prometheus" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 3,
      "title": "HTTP P95 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(atlas_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{path}}", "datasource": "Prometheus" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Price Check Successes",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(atlas_price_check_successes_total)", "legendFormat": "successes", "datasource": "Prometheus" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 5,
      "title": "Price Check Failures",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(atlas_price_check_failures_total)", "legendFormat": "failures", "datasource": "Prometheus" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 6,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 8, "w": 10, "h": 8 },
      "targets": [
        { "expr": "atlas_nodejs_heap_size_used_bytes", "legendFormat": "heap used", "datasource": "Prometheus" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } }
    },
    {
      "id": 7,
      "title": "Event Loop Lag (s)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 8, "w": 10, "h": 8 },
      "targets": [
        { "expr": "atlas_nodejs_eventloop_lag_seconds", "legendFormat": "event loop lag", "datasource": "Prometheus" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } }
    }
  ]
}
