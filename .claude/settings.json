    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(config/integrations.yaml)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Write(.claude/**)",
      "Write(agents/**)",
      "Write(config/**)",
      "Write(hooks/**)",
      "Write(workflows/**)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/guard-destructive.sh",
            "timeout": 10,
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/hooks/session-startup.sh",
            "timeout": 30,
            "statusMessage": "Checking Atlas status..."
          }
        ]
      }
    ]
  },
  "showTurnDuration": false
}
